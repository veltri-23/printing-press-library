{
  "api_name": "help-scout",
  "base_url": "https://api.helpscout.net/v2",
  "description": "Read-first Help Scout Inbox API surface for support operations and agent workflows.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "mcp": {
    "endpoint_tools": "hidden"
  },
  "auth": {
    "type": "bearer_token",
    "header": "Authorization",
    "env_vars": [
      "HELP_SCOUT_BEARER_AUTH"
    ],
    "env_var_specs": [
      {
        "name": "HELP_SCOUT_BEARER_AUTH",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "conversations_get",
      "description": "Get a conversation by ID. Required: conversationId. Optional: embed. Returns the GenericObject.",
      "method": "GET",
      "path": "/conversations/{conversationId}",
      "params": [
        {
          "name": "conversationId",
          "type": "int",
          "location": "path",
          "description": "Conversation id",
          "required": true
        },
        {
          "name": "embed",
          "type": "string",
          "location": "query",
          "description": "Embed"
        }
      ]
    },
    {
      "name": "conversations_get-v3",
      "description": "Get a conversation by ID using the v3 conversation representation. Required: conversationId. Returns the GenericObject.",
      "method": "GET",
      "path": "/v3/conversations/{conversationId}",
      "params": [
        {
          "name": "conversationId",
          "type": "int",
          "location": "path",
          "description": "Conversation id",
          "required": true
        }
      ]
    },
    {
      "name": "conversations_list",
      "description": "List conversations. Optional: page, mailbox, folder (plus 3 more). Returns the GenericObject.",
      "method": "GET",
      "path": "/conversations",
      "params": [
        {
          "name": "page",
          "type": "int",
          "location": "query",
          "description": "Page"
        },
        {
          "name": "mailbox",
          "type": "int",
          "location": "query",
          "description": "Mailbox"
        },
        {
          "name": "folder",
          "type": "int",
          "location": "query",
          "description": "Folder"
        },
        {
          "name": "status",
          "type": "string",
          "location": "query",
          "description": "Status"
        },
        {
          "name": "tag",
          "type": "string",
          "location": "query",
          "description": "Tag"
        },
        {
          "name": "query",
          "type": "string",
          "location": "query",
          "description": "Query"
        }
      ]
    },
