{
  "api_name": "zoho-expense",
  "base_url": "https://www.zohoapis.in/expense/v1",
  "description": "Upload receipts, tag expenses, and bundle monthly reports on Zoho Expense from the terminal",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "oauth2",
    "header": "Authorization",
    "format": "Zoho-oauthtoken {ZOHO_EXPENSE_CLIENT_ID}",
    "env_vars": [
      "ZOHO_EXPENSE_CLIENT_ID",
      "ZOHO_EXPENSE_CLIENT_SECRET",
      "ZOHO_EXPENSE_REFRESH_TOKEN",
      "ZOHO_EXPENSE_ORGANIZATION_ID"
    ],
    "env_var_specs": [
      {
        "name": "ZOHO_EXPENSE_CLIENT_ID",
        "kind": "auth_flow_input",
        "required": true,
        "sensitive": false,
        "description": "OAuth client ID from api-console.zoho.in self-client"
      },
      {
        "name": "ZOHO_EXPENSE_CLIENT_SECRET",
        "kind": "auth_flow_input",
        "required": true,
        "sensitive": true,
        "description": "OAuth client secret from api-console.zoho.in self-client"
      },
      {
        "name": "ZOHO_EXPENSE_REFRESH_TOKEN",
        "kind": "harvested",
        "required": true,
        "sensitive": true,
        "description": "Long-lived refresh token issued after exchanging a 10-min authorization code"
      },
      {
        "name": "ZOHO_EXPENSE_ORGANIZATION_ID",
        "kind": "per_call",
        "required": true,
        "sensitive": false,
        "description": "Zoho Expense organization ID (sent as X-com-zoho-expense-organizationid header on every request)"
      }
    ],
    "key_url": "https://api-console.zoho.in/"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "currencies_create",
      "description": "Add a currency to the org. Required: currency_code. Optional: exchange_rate. Returns the new Currency.",
      "method": "POST",
      "path": "/settings/currencies",
      "params": [
        {
          "name": "currency_code",
          "type": "string",
          "location": "body",
          "description": "ISO currency code (e.g. USD, INR)",
          "required": true
        },
        {
          "name": "exchange_rate",
          "type": "number",
          "location": "body",
          "description": "Initial exchange rate to base currency"
        }
      ]
    },
    {
      "name": "currencies_delete",
      "description": "Delete a currency. Required: currency_id. Destructive.",
      "method": "DELETE",
      "path": "/settings/currencies/{currency_id}",
      "params": [
        {
          "name": "currency_id",
          "type": "string",
          "location": "path",
          "required": true
        }
      ]
    },
    {
      "name": "currencies_get",
      "description": "Get a currency. Required: currency_id. Returns the Currency.",
