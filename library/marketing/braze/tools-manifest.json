      "path": "/campaigns/data_series",
      "params": [
        {
          "name": "campaign_id",
          "type": "string",
          "location": "query",
          "description": "Campaign id",
          "required": true
        },
        {
          "name": "length",
          "type": "int",
          "location": "query",
          "description": "Length"
        },
        {
          "name": "ending_at",
          "type": "string",
          "location": "query",
          "description": "Ending at"
        }
      ]
