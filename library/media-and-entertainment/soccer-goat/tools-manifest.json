          "name": "player_id",
          "type": "string",
          "location": "path",
          "description": "Player id",
          "required": true
        }
      ]
    },
    {
      "name": "players_stats_get-player",
      "description": "Get Player Stats. Required: player_id. Returns array of PlayerStat.",
      "method": "GET",
      "path": "/players/{player_id}/stats",
      "no_auth": true,
      "params": [
        {
          "name": "player_id",
