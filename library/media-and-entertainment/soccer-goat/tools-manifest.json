      "method": "GET",
      "path": "/players/{player_id}/injuries",
      "no_auth": true,
      "params": [
        {
          "name": "player_id",
          "type": "string",
          "location": "path",
          "description": "Player id",
          "required": true
        },
        {
          "name": "page_number",
          "type": "string",
          "location": "query",
          "description": "Page number"
