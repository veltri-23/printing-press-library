      "path": "/players/{player_id}/market_value",
      "no_auth": true,
      "params": [
        {
          "name": "player_id",
          "type": "string",
          "location": "path",
          "description": "Player id",
          "required": true
        }
      ]
    },
    {
      "name": "players_profile_get-player",
      "description": "Get Player Profile. Required: player_id. Returns array of string.",
      "method": "GET",
      "path": "/players/{player_id}/profile",
      "no_auth": true,
      "params": [
