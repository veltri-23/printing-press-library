{
  "api_name": "goodreads-web-undocumented",
  "base_url": "https://www.goodreads.com",
  "description": "This is an evidence-backed starting map for a future Goodreads CLI. Goodreads has no current\npublic developer API, so these routes are reverse-engineered from the logged-in web app.\n\nEvidence was captured on 2026-05-22 with browser-harness-js. Raw artifacts live under\ngoodreads/proofs/ and are mode 0600 because they contain account-visible metadata.\n\nThis spec intentionally does not include cookies, CSRF tokens, request headers, response bodies,\nor raw Kindle highlight text.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "mcp": {
    "endpoint_tools": "hidden",
    "orchestration": "code"
  },
  "auth": {
    "type": "api_key",
    "header": "_session_id2",
    "in": "cookie",
    "env_vars": [
      "GOODREADS_WEB_UNDOCUMENTED_GOODREADS_COOKIE_SESSION"
    ],
    "env_var_specs": [
      {
        "name": "GOODREADS_WEB_UNDOCUMENTED_GOODREADS_COOKIE_SESSION",
        "kind": "harvested",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
