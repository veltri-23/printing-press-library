{
  "manifest_version": "0.3",
  "name": "blu-ray-pp-mcp",
  "display_name": "Blu-ray.com",
  "version": "0.0.0",
  "description": "The disc-collector's CLI for Blu-ray.com — offline catalog, live deals, and a price-drop watchlist with zero account required.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/blu-ray-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/blu-ray-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
