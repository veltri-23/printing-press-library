{
  "manifest_version": "0.3",
  "name": "framer-pp-mcp",
  "display_name": "Framer",
  "version": "0.0.0",
  "description": "CLI for managing Framer websites — CMS, canvas, code files, publishing, and site migration. Requires Node.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/framer-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/framer-pp-mcp",
      "args": [],
      "env": {
        "FRAMER_API_KEY": "${user_config.framer_api_key}"
      }
    }
  },
  "user_config": {
    "framer_api_key": {
      "type": "string",
      "title": "FRAMER_API_KEY",
      "description": "Sets FRAMER_API_KEY for the Framer MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
