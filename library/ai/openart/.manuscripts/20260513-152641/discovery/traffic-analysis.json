    "url_field": "data.url",
    "thumbnail_field": "data.thumbnailUrl",
    "metadata_field": "data.metadata",
    "recommended_interval_seconds": 5,
    "max_wait_seconds": 1200,
    "rationale": "Grok Imagine completed in ~16s for a 5s 720p video. Seedance 2 is reported by the user to take ~10 minutes per video at default settings. Cap at 20 minutes to cover the slowest case."
