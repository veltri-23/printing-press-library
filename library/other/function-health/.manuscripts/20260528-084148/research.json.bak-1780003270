  "narrative": {
    "display_name": "Function Health",
    "headline": "Every Function Health feature, plus a local SQLite store with biomarker trends across every round you've ever drawn, plus a branded shareable PDF your doctor will actually read.",
    "value_prop": "Function Health gives you a great single-round dashboard but no way to see what's drifting across years of draws — and no way to share a clean, branded lab history with your physician. function-health-pp-cli pulls every round into a local SQLite store with FTS5, exposes cross-round trend analysis nobody else offers (`goat`, `biomarker trend`, `biomarkers trending`, `biomarkers oscillating`), and renders a Function-branded PDF with your name and date of birth that an MD can read in 30 seconds.",
    "auth_narrative": "Authenticate once with your Function Health email and password via `function-health-pp-cli auth login`. The CLI exchanges those for a Firebase id-token and refresh-token, stores both in `~/.config/function-health-pp-cli/credentials.toml` (mode 0600), and auto-refreshes the id-token before its 1-hour expiry — without the `API_KEY_INVALID` failure mode that has kept the competing daveremy/function-health-mcp tool broken since May 2026. Set `FUNCTION_HEALTH_TOKEN` to override stored credentials for CI or one-shot use.",
    "quickstart": [
      {
        "command": "function-health-pp-cli auth login --email you@example.com",
        "comment": "Exchange email+password for a Firebase id-token, stored locally with mode 0600."
      },
      {
        "command": "function-health-pp-cli sync",
        "comment": "Pull every round, biomarker, recommendation, and clinician note into the local SQLite store with adaptive pacing."
      },
      {
        "command": "function-health-pp-cli goat",
        "comment": "Show the single biomarker that's drifting fastest away from Function's optimal range right now."
      },
      {
        "command": "function-health-pp-cli biomarker trend ApoB --json",
        "comment": "See every ApoB value you've ever drawn, with Function optimal range and delta — JSON for agents, sparkline in a terminal."
      },
      {
        "command": "function-health-pp-cli bundle ApoB --window 3rounds | pbcopy",
        "comment": "Compose a Markdown context block (biomarker history + clinician notes + recommendations) and paste it straight into Claude or ChatGPT."
      },
      {
        "command": "function-health-pp-cli export pdf-for-doctor --out ~/Downloads/function-history.pdf",
        "comment": "Render a Function-branded multi-round PDF with your name and DOB — the file you actually email to your MD."
      }
    ],
    "troubleshoots": [
      {
        "symptom": "`auth login` succeeds but every subsequent call returns 401 `Not allowed to perform this operation.`",
        "fix": "The id-token expired between calls. Run `function-health-pp-cli auth refresh`; if it still fails with `API_KEY_INVALID`, the refresh-token was revoked — re-run `auth login`."
      },
      {
        "symptom": "`sync` finishes but `results list` returns nothing for a recent draw",
        "fix": "Run `function-health-pp-cli sync check` — Function may not have published the round yet; this command compares local round IDs against the live requisitions list and reports whether a new round landed."
      },
      {
        "symptom": "`biomarker get \u003cname\u003e` reports `not found` for a biomarker visible in the Function web app",
        "fix": "Function reuses biomarker names across categories. Run `function-health-pp-cli biomarkers list --search \u003csubstring\u003e` to find the exact name or UUID, or pass `--id \u003cuuid\u003e`."
      },
      {
        "symptom": "`export pdf-for-doctor` renders an empty PDF",
        "fix": "PDF rendering pulls from the local SQLite — run `function-health-pp-cli sync` first if you haven't pulled any rounds yet."
      }
    ],
    "when_to_use": "Reach for function-health-pp-cli whenever an agent is asked to reason about lab trends over time, to prioritize which biomarker the user should worry about, or to produce an artifact a clinician will actually read. It is the right tool when the question requires joining data across multiple test rounds, when the user wants a branded PDF for a doctor, or when an agent needs a focused Markdown context block for one biomarker rather than the entire JSON export. It is the wrong tool for one-off single-result lookups on a draw that hasn't been synced yet — for those, run `sync` first or query the Function web app directly.",
    "recipes": [
      {
        "title": "Morning check-in",
        "command": "function-health-pp-cli sync check \u0026\u0026 function-health-pp-cli goat",
        "explanation": "Cheap incremental sync, then the single most-worrying biomarker right now — both calls are local after the first sync."
      },
      {
        "title": "Doctor-ready PDF",
        "command": "function-health-pp-cli export pdf-for-doctor --out ~/Downloads/function-$(date +%Y).pdf",
        "explanation": "Branded multi-round report with member name and DOB header, per-category sections, per-biomarker history sparklines."
      },
      {
        "title": "Narrow JSON for agents",
        "command": "function-health-pp-cli biomarker trend ApoB --agent --select \\\\brounds.draw_date,rounds.value,rounds.status\\\\b",
        "explanation": "Strip the response down to the three fields an agent actually reasons about; `--select` accepts dotted paths into nested response objects."
      },
      {
        "title": "LLM context bundle",
        "command": "function-health-pp-cli bundle hs-CRP --window 3rounds | pbcopy",
        "explanation": "Compose a Markdown context block — history + clinician notes + recommendations — and paste into Claude or ChatGPT for a focused conversation."
      },
