  "novel_features": [
    {
      "name": "Branded doctor PDF",
      "command": "export pdf-for-doctor",
      "description": "Render a Function-branded multi-round lab report PDF with your name and date of birth, suitable for emailing to your personal physician.",
      "rationale": "Every byte is rendered from the local SQLite store — the existing tools stop at JSON or 19-file ZIPs that doctors won't open.",
      "example": "function-health-pp-cli export pdf-for-doctor --out ~/Downloads/function-history.pdf",
      "why_it_matters": "When an agent needs to produce something the user will hand to a third party, this is the durable artifact — not a JSON blob.",
      "group": "Doctor-ready outputs"
    },
    {
      "name": "Biomarker trend across all rounds",
      "command": "biomarker trend",
      "description": "Every value of a biomarker across every round you've ever drawn, with the delta from Function's optimal range, an ASCII sparkline in the terminal, and structured JSON for agents.",
      "rationale": "Requires a cross-round join across SQLite — impossible in the per-round JSON-file model the existing competitors use.",
      "example": "function-health-pp-cli biomarker trend ApoB --json",
      "why_it_matters": "When the agent is asked 'how has X changed', this is the one query that answers it without re-fetching anything.",
      "group": "Local-SQL trend analysis"
    },
    {
      "name": "Drift-toward-optimal goat",
      "command": "goat",
      "description": "Ranks every biomarker by distance-from-optimal multiplied by its slope-away-from-optimal across the last 3 rounds; returns the single most worrying biomarker right now with reasoning fields.",
      "rationale": "Pure SQL over the local store — no LLM, no external service. The 'most worrying' answer requires cross-round joins no single API call provides.",
      "example": "function-health-pp-cli goat --agent",
      "why_it_matters": "When the agent is asked 'what should I worry about', this is the one-call answer.",
      "group": "Local-SQL trend analysis"
    },
    {
      "name": "Trending-worse cohort",
      "command": "biomarkers trending",
      "description": "Lists every biomarker whose slope across the last N rounds points away from Function's optimal range, sorted by magnitude.",
      "rationale": "SQLite window over results with a linear-fit slope over each biomarker's draw_date series — purely local.",
      "example": "function-health-pp-cli biomarkers trending --direction worse --last 3 --json",
      "why_it_matters": "Lets the agent prioritize a long biomarker list without burning the user's context window on every reading.",
      "group": "Local-SQL trend analysis"
    },
    {
      "name": "Category-level health-score timeline",
      "command": "category trend",
      "description": "For one of the ~13 categories, returns a per-round aggregate score (percent of biomarkers inside Function's optimal range) over time.",
      "rationale": "GROUP BY round_id over results filtered by category_id — pure SQL aggregate from synced data.",
      "example": "function-health-pp-cli category trend cardiovascular --json",
      "why_it_matters": "Rolls up 100+ biomarkers into a single trajectory per body system, so the agent can summarize organ-level changes.",
      "group": "Local-SQL trend analysis"
    },
    {
      "name": "Oscillation detector",
      "command": "biomarkers oscillating",
      "description": "Biomarkers that crossed the optimal-range boundary at least twice in the last N rounds — flags instability separate from trend.",
      "rationale": "SQLite window counting sign-changes of (value − optimal_low) × (value − optimal_high) across consecutive draws.",
      "example": "function-health-pp-cli biomarkers oscillating --rounds 4",
      "why_it_matters": "Distinguishes 'unstable measurement noise' from 'consistently bad' — important when the agent is reasoning about whether a single high reading matters.",
      "group": "Local-SQL trend analysis"
    },
    {
      "name": "LLM-ready bundle composer",
      "command": "bundle",
      "description": "Composes a single Markdown file with a biomarker's full history, every clinician note mentioning it (FTS5), Function's optimal range, and relevant recommendations — ready to paste into Claude or ChatGPT.",
      "rationale": "Local SQLite + FTS5 across results, reports, recommendations, and notes joined by biomarker name — one query, one Markdown render.",
      "example": "function-health-pp-cli bundle ApoB --window 3rounds",
      "why_it_matters": "When the agent is being asked to draft a question for the user's clinician, this is the prefab context block.",
      "group": "Agent-native plumbing"
    },
    {
      "name": "Recommendation resolution tracker",
      "command": "recommendations stale",
      "description": "Recommendations issued at least one round ago whose associated biomarker has not moved into Function's optimal range — surfaces recs the user didn't act on or that didn't work.",
      "rationale": "SQL join between recommendations and the latest two results per biomarker — flags recs whose target biomarker hasn't entered Function-optimal range.",
      "example": "function-health-pp-cli recommendations stale --json",
      "why_it_matters": "Closes the loop between guidance and outcome — the agent can ask 'did the last fix work?' instead of 'what is recommended now?'.",
      "group": "Local-SQL trend analysis"
    }
  ],
