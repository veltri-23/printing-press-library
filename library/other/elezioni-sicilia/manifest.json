    "entry_point": "bin/elezioni-sicilia-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/elezioni-sicilia-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
